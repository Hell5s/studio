
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Permite leitura pública para que as clientes vejam as fotos
      allow read: if true;
      // Permite escrita apenas para usuários autenticados (Admin)
      allow write: if request.auth != null;
    }
  }
}
