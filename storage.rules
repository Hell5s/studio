rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Regras gerais para o bucket
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Regras específicas para banners, aceitando imagens e vídeos
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
