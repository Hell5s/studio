
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA v1.7
     * Estabilização de acesso público e proteção administrativa.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Banners: Acesso público total e explícito para leitura
    match /banners/{bannerId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Produtos: Leitura pública total
    match /products/{productId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Categorias: Leitura pública total
    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Newsletter: Qualquer um pode se inscrever
    match /newsletter_subscribers/{subscriberId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // Controle de Admin: Apenas o próprio admin
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list: if isAdmin();
    }
    
    // Regra de fallback: Negar tudo que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
