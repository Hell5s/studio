
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA v16.0
     * Sistema de Pedidos e Gestão Administrativa
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Produtos e Categorias: Leitura pública, escrita apenas admin
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos: Sistema Privado com filtragem por userId ou Email
    match /orders/{orderId} {
      allow create: if isSignedIn();
      
      // Admin lê tudo. Cliente lê o próprio.
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.customer.email.lower() == request.auth.token.email.lower()
      ));
      
      // Listagem: Exige filtro de segurança
      allow list: if isAdmin() || (isSignedIn() && (
        request.query.filters.userId == request.auth.uid ||
        request.query.filters['customer.email'] == request.auth.token.email.lower()
      ));

      allow update, delete: if isAdmin();
    }

    match /users/{userId}/favorites/{favId} {
      allow read, write: if isOwner(userId);
    }

    match /newsletter_subscribers/{s} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }
    
    match /roles_admin/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow list: if isAdmin();
    }
    
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
