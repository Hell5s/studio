
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA v20.0
     * Foco em Propriedade de Pedidos e Segurança Administrativa
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Produtos e Categorias: Leitura pública, escrita apenas admin
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos: Sistema de Propriedade Privada
    match /orders/{orderId} {
      // Qualquer usuário autenticado pode criar um pedido, desde que marque com seu próprio UID
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Leitura de documento único (get)
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // Listagem (queries): O filtro userId == request.auth.uid deve estar presente na consulta
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // Atualização permitida apenas para administradores ou proprietário (ex: cancelar pedido)
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // Exclusão permitida apenas para administradores
      allow delete: if isAdmin();
    }

    // Favoritos: Apenas o dono acessa
    match /users/{userId}/favorites/{favId} {
      allow read, write: if isOwner(userId);
    }

    // Newsletter: Inscrição pública, gestão admin
    match /newsletter_subscribers/{s} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }
    
    // Papéis Administrativos: Dono lê seu status, admin lista todos
    match /roles_admin/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow list: if isAdmin();
    }
    
    // Banners: Leitura pública, gestão admin
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bloqueio padrão para qualquer outro documento
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
