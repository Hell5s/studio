
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA REFINADAS
     * Garantindo leitura pública de banners e produtos.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Produtos: Leitura pública total
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categorias: Leitura pública total
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Banners: Leitura pública total (get e list)
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Newsletter: Qualquer um pode se inscrever
    match /newsletter_subscribers/{subscriberId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // Controle de Admin: Apenas o próprio admin ou outros admins podem ler
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list: if isAdmin();
    }
  }
}
