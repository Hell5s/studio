
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA v8.2
     * Ajuste fino nas permissões de pedidos e funções administrativas.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Produtos: Leitura pública, escrita apenas admin
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categorias: Leitura pública
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos: Criação pública, gestão admin, leitura pelo dono do pedido
    match /orders/{orderId} {
      allow create: if true;
      // Permite buscar por ID (rastreio público)
      allow get: if true; 
      // Permite listar se for admin ou se o filtro da query bater com o email do token
      allow list: if isAdmin() || (isSignedIn() && request.auth.token.email != null && request.auth.token.email == resource.data.customerEmail);
      allow update, delete: if isAdmin();
    }

    // Favoritos: Permitir que qualquer usuário autenticado gerencie seu próprio subconjunto
    match /users/{userId}/favorites/{favId} {
      allow read, write: if isOwner(userId);
    }

    // Newsletter e Papéis Admin
    match /newsletter_subscribers/{s} { allow create: if true; allow read, delete: if isAdmin(); }
    match /roles_admin/{a} { allow get: if isSignedIn() && request.auth.uid == a; allow list: if isAdmin(); }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
