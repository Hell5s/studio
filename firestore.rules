
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA v21.0
     * Sistema de Propriedade por userId
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Produtos e Categorias: Leitura pública, escrita apenas admin
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos: Sistema de Propriedade Privada por userId
    match /orders/{orderId} {
      // Qualquer usuário autenticado pode criar um pedido
      allow create: if isSignedIn();

      // Leitura, atualização e exclusão permitidas APENAS se for o dono ou admin
      // Nota: Para listar (query), o filtro userId == request.auth.uid deve estar presente
      allow read, update, delete: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        // Fallback temporário para migração: permite ler se o e-mail bater e userId não existir
        (!('userId' in resource.data) && resource.data.customer.email == request.auth.token.email)
      ));
    }

    // Favoritos: Apenas o dono acessa
    match /users/{userId}/favorites/{favId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Newsletter: Inscrição pública, gestão admin
    match /newsletter_subscribers/{s} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }
    
    // Papéis Administrativos: Dono lê seu status, admin lista todos
    match /roles_admin/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow list: if isAdmin();
    }
    
    // Banners: Leitura pública, gestão admin
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bloqueio padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
