rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA ATUALIZADAS
     * Garante leitura pública para o catálogo e acesso administrativo via coleção roles_admin.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Regra para produtos (Leitura pública total, incluindo listagem)
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regra para categorias
    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regra para banners
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regra para assinantes da newsletter
    match /newsletter_subscribers/{subscriberId} {
      allow create: if true;
      allow get, list, delete: if isAdmin();
      allow update: if false;
    }

    // Regra para verificar papel de admin
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list, create, update, delete: if false; 
    }
  }
}