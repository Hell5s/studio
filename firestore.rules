
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA v6.0
     * Foco em acessibilidade total para favoritos e segurança de pedidos.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Produtos: Leitura pública, escrita apenas admin
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categorias: Leitura pública
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos: Criação pública, gestão admin, leitura pelo dono do pedido (e-mail)
    match /orders/{orderId} {
      allow create: if true;
      // Permite ler se for admin OU se o e-mail no pedido for o mesmo do usuário logado
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email == resource.data.customerEmail);
      allow update, delete: if isAdmin();
    }

    // Favoritos: Permitir que qualquer usuário autenticado gerencie seu próprio subconjunto
    match /users/{userId}/favorites/{favId} {
      allow read, write: if isOwner(userId);
    }

    // Newsletter e Papéis Admin
    match /newsletter_subscribers/{s} { allow create: if true; allow read, delete: if isAdmin(); }
    match /roles_admin/{a} { allow get: if isSignedIn() && request.auth.uid == a; allow list: if isAdmin(); }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
