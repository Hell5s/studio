
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA v4.5
     * Foco em acessibilidade total para favoritos e segurança administrativa.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Produtos: Leitura pública, escrita apenas admin
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categorias: Leitura pública
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos: Criação pública, gestão admin
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Favoritos: Regra prioritária e explícita
    // Permite que qualquer usuário autenticado (incluindo anônimo) gerencie seus próprios favoritos
    match /users/{uid}/favorites/{favId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Newsletter e Papéis Admin
    match /newsletter_subscribers/{s} { allow create: if true; allow read, delete: if isAdmin(); }
    match /roles_admin/{a} { allow get: if isSignedIn() && request.auth.uid == a; allow list: if isAdmin(); }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
