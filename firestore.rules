rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA v14.0
     * Sistema de Pedidos e Gestão Administrativa
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Verifica se o UID do usuário existe na coleção de administradores
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Produtos e Categorias: Leitura pública, escrita apenas admin
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos: Sistema Privado com filtragem por userId ou Email
    match /orders/{orderId} {
      // Cliente pode criar o próprio pedido
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid || 
        request.resource.data.customer.email.lower() == request.auth.token.email.lower()
      );
      
      // Admin pode ler tudo. Cliente pode ler seus próprios pedidos.
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.customer.email.lower() == request.auth.token.email.lower()
      ));
      
      // Listagem (queries): Requer filtro por userId ou Email para clientes, ou ser Admin
      allow list: if isAdmin() || (isSignedIn() && (
        request.query.filters.userId == request.auth.uid ||
        request.query.filters['customer.email'] == request.auth.token.email.lower()
      ));

      // Apenas Admin pode atualizar status ou deletar
      allow update, delete: if isAdmin();
    }

    // Favoritos: Gestão por UID
    match /users/{userId}/favorites/{favId} {
      allow read, write: if isOwner(userId);
    }

    // Newsletter: Inscrição pública, leitura apenas admin
    match /newsletter_subscribers/{s} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }
    
    // Papéis Admin: Permite que o usuário verifique sua própria permissão de forma segura
    match /roles_admin/{uid} {
      allow get: if isSignedIn() && request.auth.uid == uid;
      allow list: if isAdmin();
    }
    
    // Banners: Leitura pública
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bloqueio padrão para qualquer outro caminho
    match /{document=**} {
      allow read, write: if false;
    }
  }
}