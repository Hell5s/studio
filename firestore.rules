
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Configurações Globais: Leitura pública, escrita para admins
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Produtos: Leitura pública, escrita para usuários logados
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if true;
        allow delete: if isSignedIn();
      }
    }
    
    // Categorias: Leitura pública, escrita para usuários logados
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Pedidos: Leitura e escrita para usuários logados
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn();
    }

    // Papéis Administrativos
    match /roles_admin/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow list: if isSignedIn();
    }
    
    // Banners e Newsletter
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /newsletter_subscribers/{s} {
      allow create: if true;
      allow read, delete: if isSignedIn();
    }

    // Favoritos: Apenas o dono pode ler/escrever
    match /users/{userId}/favorites/{favId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
