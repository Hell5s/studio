rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA
     * Garante acesso público para leitura do catálogo e restrições administrativas.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Regra para produtos (Leitura pública total)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regra para categorias
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regra para banners
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regra para assinantes da newsletter
    match /newsletter_subscribers/{subscriberId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // Regra para verificar papel de admin
    match /roles_admin/{adminUid} {
      allow read: if isSignedIn() && request.auth.uid == adminUid;
    }
  }
}