
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TODA BELA - REGRAS DE SEGURANÇA v4.1
     * Correção de permissões para favoritos e gestão.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Produtos: Leitura pública total
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categorias: Leitura pública total
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos: Qualquer um pode criar, apenas admin pode ler/gerenciar
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Newsletter: Qualquer um pode se inscrever
    match /newsletter_subscribers/{subscriberId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // Controle de Admin: Apenas o próprio admin pode ler seu cargo
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list: if isAdmin();
    }

    // Favoritos: Apenas a própria usuária pode gerenciar seus favoritos
    // O uso de request.auth.uid == userId é a forma mais segura de garantir a posse
    match /users/{userId}/favorites/{productId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Regra de fallback: Negar tudo que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
