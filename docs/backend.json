
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a single product available in the store catalog.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "cost": { "type": "number", "description": "Admin only: Cost price from supplier" },
        "supplierUrl": { "type": "string", "format": "uri", "description": "Admin only: Link to supplier product" },
        "supplierName": { "type": "string" },
        "badge": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "stock": { "type": "number" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "variations": { "type": "array", "items": { "type": "object" } },
        "featured": { "type": "boolean" },
        "published": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "inactive", "draft"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "image", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "orderNumber": { "type": "string" },
        "userId": { "type": "string" },
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zip": { "type": "string" }
          }
        },
        "items": { "type": "array", "items": { "type": "object" } },
        "subtotal": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "ordered", "shipped", "delivered", "canceled"] },
        "trackingCode": { "type": "string" },
        "internalNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "minOrderValue": { "type": "number" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "usageLimit": { "type": "number" },
        "usedCount": { "type": "number" },
        "active": { "type": "boolean" }
      }
    },
    "StoreConfig": {
      "title": "StoreConfig",
      "type": "object",
      "properties": {
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "freeShippingThreshold": { "type": "number" },
        "announcementBar": { "type": "string" },
        "policies": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/products/{productId}": { "schema": { "$ref": "#/backend/entities/Product" }, "description": "Catálogo de produtos" },
    "/orders/{orderId}": { "schema": { "$ref": "#/backend/entities/Order" }, "description": "Pedidos da loja" },
    "/coupons/{couponId}": { "schema": { "$ref": "#/backend/entities/Coupon" }, "description": "Cupons de desconto" },
    "/store_config/settings": { "schema": { "$ref": "#/backend/entities/StoreConfig" }, "description": "Configurações globais" },
    "/roles_admin/{uid}": { "description": "Controle de acesso administrativo" }
  }
}
