
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a single product available in the store catalog.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "cost": { "type": "number" },
        "profit": { "type": "number" },
        "margin": { "type": "number" },
        "badge": { "type": "string" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "brand": { "type": "string" },
        "sku": { "type": "string" },
        "collection": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "stock": { "type": "number" },
        "weight": { "type": "number" },
        "dimensions": {
          "type": "object",
          "properties": {
            "height": { "type": "number" },
            "width": { "type": "number" },
            "length": { "type": "number" }
          }
        },
        "shippingTime": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "variations": { "type": "array", "items": { "type": "object" } },
        "featured": { "type": "boolean" },
        "published": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "inactive", "draft"] },
        "bestseller": { "type": "boolean" },
        "source": { "type": "string" },
        "sourceUrl": { "type": "string", "format": "uri" },
        "vendorName": { "type": "string" },
        "originalPrice": { "type": "number" },
        "seo": {
          "type": "object",
          "properties": {
            "metaTitle": { "type": "string" },
            "metaDescription": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "image", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "order"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Registros de pedidos feitos pelos clientes.",
      "properties": {
        "orderNumber": { "type": "string" },
        "userId": { "type": "string" },
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zip": { "type": "string" }
          }
        },
        "items": { "type": "array", "items": { "type": "object" } },
        "subtotal": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "trackingCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderNumber", "userId", "items", "total", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "type": "object",
      "description": "Avaliação de produto deixada por uma cliente.",
      "properties": {
        "user": { "type": "string" },
        "rating": { "type": "number" },
        "headline": { "type": "string" },
        "comment": { "type": "string" },
        "size": { "type": "string" },
        "recommended": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["user", "rating", "comment", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Catálogo completo de produtos"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": { "$ref": "#/backend/entities/Review" },
      "description": "Avaliações das clientes para cada produto"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Pedidos dos clientes"
    },
    "/roles_admin/{uid}": {
      "description": "Permissões de administrador"
    }
  }
}
