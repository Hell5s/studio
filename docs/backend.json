
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a single product available in the store catalog.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "badge": { "type": "string" },
        "categoryId": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "stock": { "type": "number" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "featured": { "type": "boolean" },
        "published": { "type": "boolean" },
        "source": { "type": "string" },
        "sourceUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "image", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "order"]
    },
    "NewsletterSubscriber": {
      "title": "NewsletterSubscriber",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subscriptionDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "subscriptionDate"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": { "$ref": "#/backend/entities/Product" },
          "description": "Catalogo de produtos"
        }
      },
      {
        "path": "/categories/{categoryId}",
        "definition": {
          "entityName": "Category",
          "schema": { "$ref": "#/backend/entities/Category" },
          "description": "Categorias de produtos"
        }
      },
      {
        "path": "/newsletter_subscribers/{subscriberId}",
        "definition": {
          "entityName": "NewsletterSubscriber",
          "schema": { "$ref": "#/backend/entities/NewsletterSubscriber" },
          "description": "Assinantes da newsletter"
        }
      },
      {
        "path": "/roles_admin/{adminUid}",
        "definition": {
          "entityName": "UserRole",
          "description": "Papeis administrativos"
        }
      }
    ]
  }
}
