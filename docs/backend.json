
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a single product available in the store catalog.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "badge": { "type": "string" },
        "categoryId": { "type": "string" },
        "category": { "type": "string" },
        "collection": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "stock": { "type": "number" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "featured": { "type": "boolean" },
        "published": { "type": "boolean" },
        "bestseller": { "type": "boolean" },
        "source": { "type": "string" },
        "sourceUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "image", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "order"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Registros de pedidos feitos pelos clientes.",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "customerPhone": { "type": "string" },
        "customerAddress": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "number": { "type": "string" },
            "complement": { "type": "string" },
            "neighborhood": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zipCode": { "type": "string" }
          }
        },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pendente", "Pago", "Enviado", "Entregue", "Cancelado"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "items", "total", "status", "createdAt"]
    },
    "NewsletterSubscriber": {
      "title": "NewsletterSubscriber",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subscriptionDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "subscriptionDate"]
    },
    "Favorite": {
      "title": "Favorite",
      "type": "object",
      "description": "Representa um produto favoritado por uma usuária.",
      "properties": {
        "productId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "addedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Catálogo de produtos"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/backend/entities/Category" },
      "description": "Categorias de produtos"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Pedidos dos clientes"
    },
    "/newsletter_subscribers/{subscriberId}": {
      "schema": { "$ref": "#/backend/entities/NewsletterSubscriber" },
      "description": "Assinantes da newsletter"
    },
    "/roles_admin/{adminUid}": {
      "description": "Papéis administrativos"
    },
    "/users/{userId}/favorites/{productId}": {
      "schema": { "$ref": "#/backend/entities/Favorite" },
      "description": "Produtos favoritos da usuária"
    }
  }
}
