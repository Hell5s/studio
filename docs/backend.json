
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a single product available in the store catalog.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "badge": { "type": "string" },
        "categoryId": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "stock": { "type": "number" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "featured": { "type": "boolean" },
        "published": { "type": "boolean" },
        "bestseller": { "type": "boolean" },
        "source": { "type": "string" },
        "sourceUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "image", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "order"]
    },
    "Banner": {
      "title": "Banner",
      "type": "object",
      "description": "Banners promocionais da home",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "active": { "type": "boolean" },
        "order": { "type": "number" },
        "ctaText": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "imageUrl", "active"]
    },
    "NewsletterSubscriber": {
      "title": "NewsletterSubscriber",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subscriptionDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "subscriptionDate"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Catálogo de produtos"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/backend/entities/Category" },
      "description": "Categorias de produtos"
    },
    "/banners/{bannerId}": {
      "schema": { "$ref": "#/backend/entities/Banner" },
      "description": "Banners da home"
    },
    "/newsletter_subscribers/{subscriberId}": {
      "schema": { "$ref": "#/backend/entities/NewsletterSubscriber" },
      "description": "Assinantes da newsletter"
    },
    "/roles_admin/{adminUid}": {
      "description": "Papéis administrativos"
    }
  }
}
